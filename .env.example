# URL base da API (PHP/MySQL) — obrigatório
VITE_API_URL=http://localhost:8000

# Chave da API Groq para a assistente Weza — usada apenas em desenvolvimento local (.env.local)
# ATENÇÃO: esta chave fica embutida no bundle do browser em produção. Ver aviso de segurança no README.
VITE_GROQ_API_KEY=

# DSN do Sentry para monitorização de erros em produção (opcional)
VITE_SENTRY_DSN=
